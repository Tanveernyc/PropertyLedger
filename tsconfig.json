{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    // Expose jest globals (describe/it/expect) to the typechecker in test files.
    "types": ["jest"],
    // "@/..." resolves to src/ — prefer aliases over deep relative imports.
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
